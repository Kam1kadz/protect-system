<UserControl x:Class="KMGuardLoader.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" FontSize="20" FontWeight="Bold"
                   Foreground="#ffffff" Margin="0,0,0,24"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- RAM -->
                <TextBlock Text="RAM (MB)" Style="{StaticResource Label}"/>
                <StackPanel Orientation="Horizontal">
                    <Slider Minimum="1024" Maximum="16384" TickFrequency="512"
                            IsSnapToTickEnabled="True"
                            Value="{Binding RamMb}" Width="300"/>
                    <TextBlock Text="{Binding RamMb}" Foreground="#a1a1aa"
                               Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Fullscreen -->
                <TextBlock Text="Fullscreen on launch" Style="{StaticResource Label}" Margin="0,16,0,0"/>
                <CheckBox IsChecked="{Binding Fullscreen}" Foreground="#ffffff"/>

                <!-- Window size -->
                <TextBlock Text="Window size" Style="{StaticResource Label}" Margin="0,16,0,0"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding Width}" Style="{StaticResource InputBox}" Width="80"/>
                    <TextBlock Text="×" Foreground="#a1a1aa" Margin="8,0" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding Height}" Style="{StaticResource InputBox}" Width="80"/>
                </StackPanel>

                <!-- Language -->
                <TextBlock Text="Language" Style="{StaticResource Label}" Margin="0,16,0,0"/>
                <ComboBox SelectedValue="{Binding Language}"
                          SelectedValuePath="Tag" Width="160">
                    <ComboBoxItem Content="English" Tag="en"/>
                    <ComboBoxItem Content="Русский" Tag="ru"/>
                </ComboBox>

                <!-- Java path -->
                <TextBlock Text="Java path (leave empty for auto)"
                           Style="{StaticResource Label}" Margin="0,16,0,0"/>
                <TextBox Text="{Binding JavaPath}" Style="{StaticResource InputBox}"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryBtn}"
                    Command="{Binding CancelCommand}" Width="90" Margin="0,0,10,0"/>
            <Button Content="Save" Style="{StaticResource PrimaryBtn}"
                    Command="{Binding SaveCommand}" Width="90"/>
        </StackPanel>
    </Grid>
</UserControl>