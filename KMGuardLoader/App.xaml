<Application x:Class="KMGuardLoader.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>

        <!-- Colors -->
        <SolidColorBrush x:Key="AccentBrush"   Color="#7c3aed"/>
        <SolidColorBrush x:Key="SurfaceBrush"  Color="#18181b"/>
        <SolidColorBrush x:Key="BorderBrush"   Color="#2a2a2e"/>
        <SolidColorBrush x:Key="FgBrush"       Color="#ffffff"/>
        <SolidColorBrush x:Key="FgMutedBrush"  Color="#a1a1aa"/>

        <!-- InputBox -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"   Value="#18181b"/>
            <Setter Property="Foreground"   Value="#ffffff"/>
            <Setter Property="BorderBrush"  Value="#2a2a2e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="10,8"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="CaretBrush"   Value="#7c3aed"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- InputBox for PasswordBox -->
        <Style x:Key="InputBox" TargetType="PasswordBox">
            <Setter Property="Background"   Value="#18181b"/>
            <Setter Property="Foreground"   Value="#ffffff"/>
            <Setter Property="BorderBrush"  Value="#2a2a2e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="10,8"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PrimaryBtn -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"  Value="#7c3aed"/>
            <Setter Property="Foreground"  Value="#ffffff"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6d28d9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SecondaryBtn -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#a1a1aa"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderBrush"     Value="#2a2a2e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#18181b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TitleBarBtn -->
        <Style x:Key="TitleBarBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#71717a"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#27272a"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- IconBtn -->
        <Style x:Key="IconBtn" TargetType="Button" BasedOn="{StaticResource SecondaryBtn}">
            <Setter Property="Width"  Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Label -->
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#71717a"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

    </Application.Resources>
</Application>