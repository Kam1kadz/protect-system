# ── Postgres ───────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kmguard
POSTGRES_USER=kmguard
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

DATABASE_URL=postgres://kmguard:CHANGE_ME_STRONG_PASSWORD@postgres:5432/kmguard?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_REDIS_PASS@redis:6379/0

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_ACCESS
MINIO_SECRET_KEY=CHANGE_ME_SECRET
MINIO_BUCKET=kmguard
MINIO_USE_SSL=false

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_64CHARS_HEX_ACCESS
JWT_REFRESH_SECRET=CHANGE_ME_64CHARS_HEX_REFRESH
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── App ───────────────────────────────────────────────────────────────────────
MASTER_KEY=CHANGE_ME_64CHARS_HEX_MASTER
SUPER_ADMIN_KEY=CHANGE_ME_SUPERADMIN_KEY
HMAC_DRIFT=30
NONCE_TTL=60

PUBLIC_ADDR=:8080
ADMIN_ADDR=:8081

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_SITE_NAME=KMGuard
NEXT_PUBLIC_ACCENT_COLOR=#7c3aed